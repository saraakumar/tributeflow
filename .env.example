# Secrets — set these as GitHub Actions secrets (and locally in .env for testing).
ANTHROPIC_API_KEY=sk-ant-...
GITHUB_TOKEN=ghp_...                      # fine-grained PAT: Contents read/write on the website repo
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account", ...}   # full JSON key, one line
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=tributeflow@example.org
SMTP_PASSWORD=an-app-password
